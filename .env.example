# ============================================================
# DASHBOARD VERCEL — Environment Variables
# Salin file ini ke .env dan isi dengan nilai asli.
# JANGAN commit file .env ke Git!
# ============================================================

# ── API Endpoint ─────────────────────────────────────────────
# URL backend bot di VPS, diekspos via Cloudflare Tunnel (leo-bot).
# Tunnel ini sudah aktif dengan domain yogurt.biz.id:
#   bot.yogurt.biz.id   → port 8000 (webhook OTP, sudah berjalan)
#
# Tambahkan satu hostname baru di Cloudflare Dashboard untuk Stripe Verif:
#   Subdomain : api
#   Domain    : yogurt.biz.id
#   Service   : http://localhost:8383
#   → Hasilnya: https://api.yogurt.biz.id
#
# Cara tambah hostname:
#   1. Buka https://one.dash.cloudflare.com
#   2. Zero Trust → Networks → Tunnels → leo-bot → Edit
#   3. Tab "Public Hostnames" → Add a public hostname
#   4. Subdomain: api | Domain: yogurt.biz.id | Service: http://localhost:8383
API_URL=https://api.yogurt.biz.id

# ── Telegram Login Widget ────────────────────────────────────
# Username bot TANPA @ (contoh: StripeVerifBot)
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME_HERE

# ── Telegram Auth Verification (SERVER-SIDE ONLY) ────────────
# BOT_TOKEN dipakai oleh api/verify.js untuk memverifikasi
# hash dari Telegram Login Widget.
# ⚠️  JANGAN pernah expose nilai ini ke browser/client.
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
