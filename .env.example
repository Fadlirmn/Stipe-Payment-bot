# ============================================================
# STRIPE VERIF BOT — Environment Variables
# Salin file ini ke .env dan isi dengan nilai asli Anda.
# JANGAN commit file .env ke Git!
# ============================================================

# --- Telegram Bot ---
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# --- Developer Telegram IDs (pisahkan dengan koma) ---
DEV_IDS=YOUR_TELEGRAM_USER_ID_HERE

# --- Google Apps Script (pengganti Google Sheets API) ---
# URL Web App dari: Extensions → Apps Script → Deploy → New deployment
APPS_SCRIPT_URL=YOUR_APPS_SCRIPT_WEB_APP_URL_HERE

# --- Firebase (Bot — Service Account) ---
# Download dari: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_JSON=./firebase-credentials.json
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE

# --- Firebase (Dashboard Vercel — Web Config) ---
# Set variabel-variabel ini di: Vercel Dashboard → Project → Settings → Environment Variables
# Ambil nilai dari: Firebase Console → Project Settings → General → Your apps → SDK snippet
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
FIREBASE_APP_ID=YOUR_APP_ID_HERE

# --- Telegram Login Widget (Dashboard Auth) ---
# Username bot TANPA @ (contoh: StripeVerifBot)
# Dipakai oleh Telegram Login Widget di browser (public, aman)
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME_HERE
# BOT_TOKEN untuk verifikasi hash (server-side only, JANGAN expose ke client)
# Set di Vercel Environment Variables, TIDAK perlu di .env VPS
# BOT_TOKEN sudah ada di atas, dipakai ulang oleh api/verify.js

# --- Timezone ---
TIMEZONE=Asia/Jakarta

# --- Dashboard ---
# URL Dashboard real-time (Vercel)
DASHBOARD_URL=https://stipe-payment-bot.vercel.app/

# --- JWT Authentication (Local API) ---
# Kunci rahasia untuk menandatangani token JWT Dashboard (isi dengan string panjang acak)
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# --- PostgreSQL Database ---
POSTGRES_HOST=YOUR_POSTGRES_HOST_HERE
POSTGRES_PORT=5432
POSTGRES_DB=stripe_verif
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD_HERE
