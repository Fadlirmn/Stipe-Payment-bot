# ============================================================
# DASHBOARD VERCEL — Environment Variables
# Salin file ini ke .env dan isi dengan nilai asli.
# JANGAN commit file .env ke Git!
# ============================================================

# ── Firebase Web Config ──────────────────────────────────────
# Ambil dari: Firebase Console → Project Settings → General
#             → Your apps → SDK snippet (Config)
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
FIREBASE_APP_ID=YOUR_APP_ID_HERE

# ── Telegram Login Widget ────────────────────────────────────
# Username bot TANPA @ (contoh: StripeVerifBot)
# Dipakai di browser untuk menampilkan tombol login Telegram.
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME_HERE

# ── Telegram Auth Verification (SERVER-SIDE ONLY) ────────────
# BOT_TOKEN dipakai oleh api/verify.js untuk memverifikasi
# hash dari Telegram Login Widget.
# ⚠️  JANGAN pernah expose nilai ini ke browser/client.
# Di Vercel: set via Dashboard → Settings → Environment Variables.
# Lokal: isi di sini hanya untuk testing api/verify.js secara lokal.
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
